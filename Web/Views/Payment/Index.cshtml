@model IEnumerable<Payment>
@{
    ViewData["Title"] = "Payments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Payment Management</h3>
    <div class="d-flex gap-2">
        <a asp-action="Overdue" class="btn btn-outline-danger btn-sm"><i class="bi bi-exclamation-triangle me-1"></i>Overdue</a>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Payment</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Student</th>
                    <th>Amount</th>
                    <th>Due Date</th>
                    <th>Paid Date</th>
                    <th>Semester</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td>@payment.PaymentId</td>
                        <td>@payment.Student?.FullName</td>
                        <td class="fw-semibold">TL @payment.Amount.ToString("N0")</td>
                        <td>@payment.DueDate.ToString("dd/MM/yyyy")</td>
                        <td>@(payment.PaidDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>@(payment.Semester ?? "-")</td>
                        <td>
                            @if (payment.Status == "Paid")
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else if (payment.Status == "Overdue")
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td>
                            @if (payment.Status != "Paid")
                            {
                                <form asp-action="RecordPayment" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="paymentId" value="@payment.PaymentId" />
                                    <button type="submit" class="btn btn-sm btn-success" title="Record Payment">
                                        <i class="bi bi-check-lg"></i> Pay
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
