@model DashboardViewModel
@{
    ViewData["Title"] = "Overview Dashboard";
}

<div class="page-hero">
    <div>
        <p class="eyebrow mb-2">Operations Overview</p>
        <h2 class="fw-bold mb-2">Overview Dashboard</h2>
        <p class="mb-0">Occupancy, collections, and maintenance activity across all dormitory buildings.</p>
    </div>
    <div class="hero-stat">
        <span class="hero-stat-label">Current occupancy</span>
        <strong>@Model.OccupancyRate%</strong>
        <span class="hero-stat-meta">Current room utilization</span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card border-0 h-100">
            <div class="card-body">
                <div class="metric-card-head">
                    <div>
                        <span class="metric-label">Active Students</span>
                        <h3 class="fw-bold">@Model.ActiveStudents.ToString("N0")</h3>
                    </div>
                    <span class="metric-icon"><i class="bi bi-people-fill"></i></span>
                </div>
                <p class="metric-note">Students currently assigned to a dormitory room.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card border-0 h-100">
            <div class="card-body">
                <div class="metric-card-head">
                    <div>
                        <span class="metric-label">Occupancy Rate</span>
                        <h3 class="fw-bold">@Model.OccupancyRate%</h3>
                    </div>
                    <span class="metric-icon"><i class="bi bi-buildings-fill"></i></span>
                </div>
                <p class="metric-note">Capacity utilization across all active buildings.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card border-0 h-100">
            <div class="card-body">
                <div class="metric-card-head">
                    <div>
                        <span class="metric-label">Collected Fees</span>
                        <h3 class="fw-bold">TL @(Model.CollectedFees >= 1000000 ? (Model.CollectedFees / 1000000).ToString("0.##") + "M" : Model.CollectedFees.ToString("N0"))</h3>
                    </div>
                    <span class="metric-icon"><i class="bi bi-wallet2"></i></span>
                </div>
                <p class="metric-note">Payments successfully recorded during the active period.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card metric-card border-0 h-100">
            <div class="card-body">
                <div class="metric-card-head">
                    <div>
                        <span class="metric-label">Open Requests</span>
                        <h3 class="fw-bold">@Model.OpenRequests</h3>
                    </div>
                    <span class="metric-icon"><i class="bi bi-tools"></i></span>
                </div>
                <p class="metric-note">Maintenance items that still need dormitory staff attention.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card chart-card border-0 h-100">
            <div class="card-body">
                <div class="section-heading">
                    <h4 class="fw-bold">Occupancy by Building</h4>
                    <p>Compare how room usage is distributed between residence blocks.</p>
                </div>
                <canvas id="occupancyChart" height="190"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card chart-card border-0 h-100">
            <div class="card-body">
                <div class="section-heading">
                    <h4 class="fw-bold">Payment Status</h4>
                    <p>See the current balance between paid, pending, and overdue records.</p>
                </div>
                <canvas id="paymentChart" height="190"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const occupancyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyByBuilding.Keys));
        const occupancyValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyByBuilding.Values));
        const occupancyPalette = ['#2e5b46', '#4b765f', '#6f9380', '#c96f43', '#d3aa57'];

        const occupancyCtx = document.getElementById('occupancyChart').getContext('2d');
        new Chart(occupancyCtx, {
            type: 'bar',
            data: {
                labels: occupancyLabels,
                datasets: [{
                    label: 'Occupancy %',
                    data: occupancyValues,
                    backgroundColor: occupancyLabels.map((_, index) => occupancyPalette[index % occupancyPalette.length]),
                    borderRadius: 14,
                    borderSkipped: false,
                    barThickness: 38
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#5f665d' }
                    },
                    y: {
                        beginAtZero: true,
                        max: 100,
                        ticks: {
                            color: '#5f665d',
                            callback: value => value + '%'
                        },
                        grid: { color: 'rgba(45, 67, 54, 0.08)' }
                    }
                }
            }
        });

        const paymentCtx = document.getElementById('paymentChart').getContext('2d');
        const paymentData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PaymentStatusDistribution));
        const total = Object.values(paymentData).reduce((sum, value) => sum + value, 0);
        const paidPct = total > 0 ? Math.round(((paymentData['Paid'] || 0) / total) * 100) : 0;

        new Chart(paymentCtx, {
            type: 'doughnut',
            data: {
                labels: ['Paid', 'Pending', 'Overdue'],
                datasets: [{
                    data: [paymentData['Paid'] || 0, paymentData['Pending'] || 0, paymentData['Overdue'] || 0],
                    backgroundColor: ['#2e5b46', '#d3aa57', '#c96f43'],
                    hoverOffset: 6,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '68%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            boxWidth: 10,
                            color: '#5f665d'
                        }
                    }
                }
            },
            plugins: [{
                id: 'centerText',
                beforeDraw: function (chart) {
                    const ctx = chart.ctx;
                    const centerX = (chart.chartArea.left + chart.chartArea.right) / 2;
                    const centerY = (chart.chartArea.top + chart.chartArea.bottom) / 2;
                    ctx.save();
                    ctx.font = '700 24px Georgia';
                    ctx.fillStyle = '#2e5b46';
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'middle';
                    ctx.fillText(paidPct + '%', centerX, centerY);
                    ctx.restore();
                }
            }]
        });
    </script>
}
