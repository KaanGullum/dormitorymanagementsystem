@{
    ViewData["Title"] = "Welcome";
}

<div class="page-hero">
    <div>
        <p class="eyebrow mb-2">Student Services</p>
        <h2 class="fw-bold mb-2">Welcome, @User.Identity?.Name</h2>
        <p class="mb-0">Room information and maintenance request management.</p>
    </div>
    <div class="hero-stat">
        <span class="hero-stat-label">Access level</span>
        <strong>Student</strong>
        <span class="hero-stat-meta">Authorized student workspace</span>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card feature-card border-0 h-100">
            <div class="card-body text-center py-4">
                <span class="feature-icon d-inline-flex">
                    <i class="bi bi-door-open-fill"></i>
                </span>
                <h4 class="fw-bold">Rooms</h4>
                <p class="text-muted">View room availability and occupancy information.</p>
                <a asp-controller="Room" asp-action="Index" class="btn btn-outline-primary btn-sm">View Rooms</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card feature-card border-0 h-100">
            <div class="card-body text-center py-4">
                <span class="feature-icon sun d-inline-flex">
                    <i class="bi bi-tools"></i>
                </span>
                <h4 class="fw-bold">Maintenance Requests</h4>
                <p class="text-muted">Create and track maintenance requests for your room.</p>
                <a asp-controller="Maintenance" asp-action="Index" class="btn btn-outline-warning btn-sm">Go to Maintenance</a>
            </div>
        </div>
    </div>
</div>

<div class="info-strip mt-4">
    <h5 class="fw-bold mb-2"><i class="bi bi-info-circle me-2"></i>Information</h5>
    <p class="text-muted mb-0">
        Student accounts can view room information and submit maintenance requests.
        Payments, documents, and penalty records are managed by dormitory administration.
    </p>
</div>
