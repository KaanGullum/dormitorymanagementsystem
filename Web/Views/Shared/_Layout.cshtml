@{
    bool isStudent = User.IsInRole("Student");
    bool isSystemAdmin = User.IsInRole("SystemAdmin");
    bool isStaff = isSystemAdmin || User.IsInRole("DormitoryManager")
                || User.IsInRole("FinanceOfficer") || User.IsInRole("DormitoryStaff");

    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    string pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    string userInitial = !string.IsNullOrWhiteSpace(User.Identity?.Name)
        ? User.Identity!.Name!.Substring(0, 1).ToUpperInvariant()
        : "U";

    string roleLabel = isStudent
        ? "Resident Student"
        : isSystemAdmin
            ? "System Administrator"
            : User.IsInRole("DormitoryManager")
                ? "Residence Manager"
                : User.IsInRole("FinanceOfficer")
                    ? "Finance Officer"
                    : User.IsInRole("DormitoryStaff")
                        ? "Residence Staff"
                        : "System User";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Residence Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <div class="app-shell d-flex">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <nav id="sidebar" class="app-sidebar position-fixed overflow-auto">
                <div class="sidebar-brand">
                    <div class="brand-badge">
                        <i class="bi bi-buildings-fill"></i>
                    </div>
                    <div class="brand-copy">
                        <h4 class="mb-1">Residence Hub</h4>
                        <small>Accommodation management</small>
                    </div>
                </div>

                <div class="sidebar-section-label">Navigation</div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentController == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span class="sidebar-text">Dashboard</span>
                        </a>
                    </li>
                    @if (isStaff)
                    {
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentController == "Student" ? "active" : "")"
                               asp-controller="Student" asp-action="Index">
                                <i class="bi bi-people-fill"></i>
                                <span class="sidebar-text">Students</span>
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentController == "Room" ? "active" : "")"
                           asp-controller="Room" asp-action="Index">
                            <i class="bi bi-door-open-fill"></i>
                            <span class="sidebar-text">Rooms</span>
                        </a>
                    </li>
                    @if (isStaff)
                    {
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentController == "Payment" ? "active" : "")"
                               asp-controller="Payment" asp-action="Index">
                                <i class="bi bi-credit-card-2-front-fill"></i>
                                <span class="sidebar-text">Payments</span>
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentController == "Maintenance" ? "active" : "")"
                           asp-controller="Maintenance" asp-action="Index">
                            <i class="bi bi-tools"></i>
                            <span class="sidebar-text">Maintenance</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentController == "Notification" ? "active" : "")"
                           asp-controller="Notification" asp-action="Index">
                            <i class="bi bi-bell-fill"></i>
                            <span class="sidebar-text">Notifications</span>
                            @await Component.InvokeAsync("NotificationBell")
                        </a>
                    </li>
                    @if (isStaff)
                    {
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentController == "Document" ? "active" : "")"
                               asp-controller="Document" asp-action="Index">
                                <i class="bi bi-folder2-open"></i>
                                <span class="sidebar-text">Documents</span>
                            </a>
                        </li>
                    }
                    @if (isStaff)
                    {
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentController == "Report" && currentAction != "AuditLog" ? "active" : "")"
                               asp-controller="Report" asp-action="Index">
                                <i class="bi bi-bar-chart-line-fill"></i>
                                <span class="sidebar-text">Reports</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentController == "Settings" ? "active" : "")"
                               asp-controller="Settings" asp-action="Index">
                                <i class="bi bi-sliders2"></i>
                                <span class="sidebar-text">Settings</span>
                            </a>
                        </li>
                    }
                    @if (isSystemAdmin)
                    {
                        <li class="nav-item mt-3">
                            <div class="sidebar-section-label">Administration</div>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentController == "User" ? "active" : "")"
                               asp-controller="User" asp-action="Index">
                                <i class="bi bi-person-gear"></i>
                                <span class="sidebar-text">Users</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentAction == "AuditLog" ? "active" : "")"
                               asp-controller="Report" asp-action="AuditLog">
                                <i class="bi bi-shield-check"></i>
                                <span class="sidebar-text">Audit Logs</span>
                            </a>
                        </li>
                    }
                </ul>

                <div class="sidebar-footer">
                    <div class="sidebar-user">
                        <div class="sidebar-user-avatar">@userInitial</div>
                        <div class="sidebar-user-meta">
                            <span class="sidebar-user-name">@User.Identity?.Name</span>
                            <span class="sidebar-user-role">@roleLabel</span>
                        </div>
                    </div>

                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-outline-light w-100" title="Logout">
                            <i class="bi bi-box-arrow-right me-2"></i>
                            <span class="logout-text">Sign out</span>
                        </button>
                    </form>
                </div>
            </nav>

            <main class="app-content">
                <div class="page-topbar">
                    <div>
                        <p class="eyebrow mb-1">Accommodation Management System</p>
                        <div class="topbar-meta">
                            <span>@pageTitle</span>
                            <span class="topbar-dot"></span>
                            <span>@roleLabel</span>
                        </div>
                    </div>
                    <div class="topbar-actions">
                        <div class="topbar-chip">
                            <i class="bi bi-calendar3 me-2"></i>@DateTime.Now.ToString("dd MMM yyyy")
                        </div>
                        <div class="topbar-chip primary">
                            <i class="bi bi-person-badge me-2"></i>@(isStudent ? "Student access" : "Staff access")
                        </div>
                    </div>
                </div>

                <div class="content-shell">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @RenderBody()
                </div>
            </main>
        }
        else
        {
            <main class="public-content w-100">
                @RenderBody()
            </main>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const body = document.body;
            const modals = Array.from(document.querySelectorAll('.modal'));

            modals.forEach(function (modalElement) {
                if (modalElement.parentElement !== body) {
                    body.appendChild(modalElement);
                }

                modalElement.addEventListener('hidden.bs.modal', function () {
                    if (document.querySelector('.modal.show')) {
                        return;
                    }

                    document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                        backdrop.remove();
                    });

                    body.classList.remove('modal-open');
                    body.style.removeProperty('overflow');
                    body.style.removeProperty('padding-right');
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
