@model IEnumerable<Notification>
@{
    ViewData["Title"] = "Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">
            <i class="bi bi-bell me-2"></i>Notifications
            @if (unreadCount > 0)
            {
                <span class="badge bg-danger ms-2">@unreadCount</span>
            }
        </h3>
        <p class="text-muted mb-0">System notifications</p>
    </div>
    @if (unreadCount > 0)
    {
        <form asp-action="MarkAllAsRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-check2-all me-1"></i>Mark All Read
            </button>
        </form>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="list-group list-group-flush">
        @foreach (var n in Model)
        {
            var icon = n.Type switch
            {
                "Warning" => "bi-exclamation-triangle-fill text-warning",
                "Alert" => "bi-exclamation-octagon-fill text-danger",
                "Success" => "bi-check-circle-fill text-success",
                _ => "bi-info-circle-fill text-primary"
            };
            <div class="list-group-item @(n.IsRead ? "" : "bg-light")">
                <div class="d-flex align-items-start">
                    <i class="bi @icon fs-4 me-3"></i>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                            <strong class="@(n.IsRead ? "text-muted" : "")">@n.Type</strong>
                            <small class="text-muted">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <p class="mb-1 @(n.IsRead ? "text-muted" : "")">@n.Message</p>
                    </div>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkAsRead" asp-route-id="@n.NotificationId" method="post" class="ms-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Mark as read">
                                <i class="bi bi-check2"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="list-group-item text-center text-muted py-4">
                <i class="bi bi-bell-slash fs-2 d-block mb-2"></i>
                No notifications yet.
            </div>
        }
    </div>
</div>
