@model AssignRoomViewModel
@{
    ViewData["Title"] = "Assign Room";
}

<h3 class="fw-bold mb-4">Assign Room to Student</h3>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="alert alert-info py-2">
            <i class="bi bi-person me-1"></i>Student: <strong>@Model.StudentName</strong>
        </div>

        <form asp-action="AssignStudent" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="StudentId" />
            <input type="hidden" asp-for="StudentName" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Select Available Room</label>
                <select asp-for="SelectedRoomId" class="form-select">
                    <option value="">-- Select a room --</option>
                    @foreach (var room in Model.AvailableRooms)
                    {
                        <option value="@room.RoomId">
                            @room.RoomNumber (@room.Building?.BuildingName) - @room.GetAvailableBeds() beds available / @room.Capacity capacity
                        </option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Check-in</button>
                <a asp-controller="Student" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
