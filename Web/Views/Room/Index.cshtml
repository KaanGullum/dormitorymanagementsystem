@model IEnumerable<Room>
@{
    ViewData["Title"] = "Rooms";
    var buildings = ViewBag.Buildings as IEnumerable<Building> ?? new List<Building>();
    var selectedBuilding = ViewBag.SelectedBuilding as int?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Room Management</h3>
    @if (User.IsInRole("SystemAdmin") || User.IsInRole("DormitoryManager"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Room</a>
    }
</div>

<div class="d-flex gap-2 mb-3 flex-wrap">
    <a asp-action="Index" class="btn btn-sm @(selectedBuilding == null ? "btn-primary" : "btn-outline-secondary")">All</a>
    @foreach (var b in buildings)
    {
        <a asp-action="Index" asp-route-buildingId="@b.BuildingId"
           class="btn btn-sm @(selectedBuilding == b.BuildingId ? "btn-primary" : "btn-outline-secondary")">
            @b.BuildingName
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Room No</th>
                    <th>Building</th>
                    <th>Floor</th>
                    <th>Type</th>
                    <th>Capacity</th>
                    <th>Occupied</th>
                    <th>Available</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in Model)
                {
                    <tr>
                        <td class="fw-semibold">@room.RoomNumber</td>
                        <td>@room.Building?.BuildingName</td>
                        <td>@room.FloorNo</td>
                        <td>@(room.RoomType ?? "-")</td>
                        <td>@room.Capacity</td>
                        <td>@room.OccupiedBeds</td>
                        <td>@room.GetAvailableBeds()</td>
                        <td>
                            @if (room.Status == "Available")
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else if (room.Status == "Full")
                            {
                                <span class="badge bg-danger">Full</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@room.Status</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
