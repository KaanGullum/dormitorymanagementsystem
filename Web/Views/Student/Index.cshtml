@model StudentReportViewModel
@{
    ViewData["Title"] = "Students";
}

@*
    Report Section 5 - Fig 5.2 (Page 10): Student Report screen
    Columns: Student No | Full Name | Program | Year | Room | Building | Status | Check-in
*@

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Student Report</h3>
        <p class="text-muted mb-0">All registered students with room, building and check-in details</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>Print
        </button>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>New Student
        </a>
    </div>
</div>


<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Search</label>
                <input name="keyword" value="@Model.SearchKeyword" class="form-control form-control-sm" placeholder="Student No or Name..." />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Building</label>
                <select name="building" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var b in Model.Buildings)
                    {
                        <option value="@b.BuildingName" selected="@(Model.FilterBuilding == b.BuildingName)">@b.BuildingName</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Year</label>
                <select name="year" class="form-select form-select-sm">
                    <option value="">All</option>
                    @for (int y = 1; y <= 6; y++)
                    {
                        <option value="@y" selected="@(Model.FilterYear == y)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Active" selected="@(Model.FilterStatus == "Active")">Active</option>
                    <option value="Left" selected="@(Model.FilterStatus == "Left")">Left</option>
                    <option value="Suspended" selected="@(Model.FilterStatus == "Suspended")">Suspended</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Student No</th>
                    <th>Full Name</th>
                    <th>Program</th>
                    <th class="text-center">Year</th>
                    <th>Room</th>
                    <th>Building</th>
                    <th>Status</th>
                    <th>Check-in</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td class="fw-semibold">@row.StudentNumber</td>
                        <td>@row.FullName</td>
                        <td class="small text-muted">@row.Program</td>
                        <td class="text-center">@row.Year</td>
                        <td class="fw-semibold">@(row.RoomNumber ?? "-")</td>
                        <td>@(row.BuildingName ?? "-")</td>
                        <td>
                            @if (row.Status == "Active")
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else if (row.Status == "Left")
                            {
                                <span class="badge bg-secondary">Left</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@row.Status</span>
                            }
                        </td>
                        <td class="small">@(row.CheckInDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@row.StudentId" class="btn btn-outline-primary btn-sm" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@row.StudentId" class="btn btn-outline-secondary btn-sm" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-controller="Room" asp-action="AssignStudent" asp-route-studentId="@row.StudentId" class="btn btn-outline-success btn-sm" title="Assign Room">
                                    <i class="bi bi-door-open"></i>
                                </a>
                                <a asp-controller="Payment" asp-action="StudentPayments" asp-route-studentId="@row.StudentId" class="btn btn-outline-info btn-sm" title="Payments">
                                    <i class="bi bi-credit-card"></i>
                                </a>
                                <a asp-controller="Document" asp-action="Index" asp-route-studentId="@row.StudentId" class="btn btn-outline-dark btn-sm" title="Documents">
                                    <i class="bi bi-folder2"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger btn-sm" title="Delete"
                                        onclick="showDeleteModal('@row.StudentId', '@row.FullName')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Rows.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">No students found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Student
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteStudentName"></strong>?</p>
                <p class="text-muted small">This action cannot be undone. Students with active room assignments cannot be deleted.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showDeleteModal(studentId, studentName) {
            document.getElementById('deleteStudentName').textContent = studentName;
            document.getElementById('deleteForm').action = '@Url.Action("Delete", "Student")/' + studentId;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
}
