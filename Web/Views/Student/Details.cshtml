@model Student
@{
    ViewData["Title"] = "Student Details";
    var housingHistory = ViewBag.HousingHistory as IEnumerable<HousingRecord> ?? new List<HousingRecord>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Student Details</h3>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold mb-3">@Model.FullName</h5>
                <table class="table table-sm table-borderless mb-0">
                    <tr><td class="text-muted">Student No</td><td class="fw-semibold">@Model.StudentNumber</td></tr>
                    <tr><td class="text-muted">Email</td><td>@Model.Email</td></tr>
                    <tr><td class="text-muted">Phone</td><td>@(Model.Phone ?? "-")</td></tr>
                    <tr><td class="text-muted">Program</td><td>@Model.Program</td></tr>
                    <tr><td class="text-muted">Year</td><td>@Model.Year</td></tr>
                    <tr>
                        <td class="text-muted">Status</td>
                        <td><span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary")">@Model.Status</span></td>
                    </tr>
                </table>
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-controller="Room" asp-action="AssignStudent" asp-route-studentId="@Model.StudentId" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-door-open me-1"></i>Assign Room
                    </a>
                    <a asp-controller="Payment" asp-action="StudentPayments" asp-route-studentId="@Model.StudentId" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-credit-card me-1"></i>Payments
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-clock-history me-1"></i>Housing History
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Room</th>
                            <th>Check-in</th>
                            <th>Check-out</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in housingHistory)
                        {
                            <tr>
                                <td>@record.Room?.RoomNumber</td>
                                <td>@record.CheckInDate.ToString("dd/MM/yyyy")</td>
                                <td>@(record.CheckOutDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>
                                    <span class="badge @(record.HousingStatus == "Active" ? "bg-success" : "bg-secondary")">
                                        @record.HousingStatus
                                    </span>
                                </td>
                            </tr>
                        }
                        @if (!housingHistory.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">No housing records.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
