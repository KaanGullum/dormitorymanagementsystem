@{
    ViewData["Title"] = "Settings";
}

<h3 class="fw-bold mb-4">System Settings</h3>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-sliders me-1"></i>Dormitory Settings
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted">Default Semester</td>
                        <td class="fw-semibold">@ViewBag.DefaultSemester</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Max Capacity Per Room</td>
                        <td class="fw-semibold">@ViewBag.MaxCapacity</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Payment Due Days</td>
                        <td class="fw-semibold">@ViewBag.PaymentDueDays days</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Overdue Penalty Rate</td>
                        <td class="fw-semibold">@ViewBag.PenaltyRate</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-bell me-1"></i>Notification & Backup
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted">Notifications</td>
                        <td class="fw-semibold">
                            @if (ViewBag.NotificationEnabled == "true")
                            {
                                <span class="badge bg-success">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Backup Path</td>
                        <td class="fw-semibold small">@ViewBag.BackupPath</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
