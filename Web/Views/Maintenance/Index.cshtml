@model IEnumerable<MaintenanceRequest>
@{
    ViewData["Title"] = "Maintenance";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Maintenance Requests</h3>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Request</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Room</th>
                    <th>Issue</th>
                    <th>Reported By</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in Model)
                {
                    <tr>
                        <td>@req.RequestId</td>
                        <td>@req.Room?.RoomNumber</td>
                        <td>@req.IssueTitle</td>
                        <td>@req.ReportedByStudent?.FullName</td>
                        <td>
                            @if (req.Priority == "High" || req.Priority == "Critical")
                            {
                                <span class="badge bg-danger">@req.Priority</span>
                            }
                            else if (req.Priority == "Medium")
                            {
                                <span class="badge bg-warning text-dark">@req.Priority</span>
                            }
                            else
                            {
                                <span class="badge bg-info">@req.Priority</span>
                            }
                        </td>
                        <td>
                            @if (req.Status == "Open")
                            {
                                <span class="badge bg-primary">Open</span>
                            }
                            else if (req.Status == "Assigned")
                            {
                                <span class="badge bg-info">Assigned</span>
                            }
                            else if (req.Status == "InProgress")
                            {
                                <span class="badge bg-warning text-dark">In Progress</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Closed</span>
                            }
                        </td>
                        <td>@req.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (req.Status != "Closed")
                            {
                                <form asp-action="Close" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="requestId" value="@req.RequestId" />
                                    <button type="submit" class="btn btn-sm btn-success" title="Close Request">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <small class="text-muted">@req.CompletedAt?.ToString("dd/MM/yyyy")</small>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
