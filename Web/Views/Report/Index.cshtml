@{
    ViewData["Title"] = "Reports";
}

<h3 class="fw-bold mb-4">Reports</h3>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-people display-4 text-primary mb-3 d-block"></i>
                <h6 class="fw-bold">Student Report</h6>
                <p class="text-muted small">View and filter all registered students</p>
                <a asp-action="StudentReport" class="btn btn-outline-primary btn-sm">View Report</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-house-door display-4 text-warning mb-3 d-block"></i>
                <h6 class="fw-bold">Housing Report</h6>
                <p class="text-muted small">Residence periods, check-in / check-out tracking</p>
                <a asp-action="HousingReport" class="btn btn-outline-warning btn-sm">View Report</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-credit-card display-4 text-success mb-3 d-block"></i>
                <h6 class="fw-bold">Payment & Maintenance</h6>
                <p class="text-muted small">Semester payment summary and open requests</p>
                <a asp-action="PaymentMaintenance" class="btn btn-outline-success btn-sm">View Report</a>
            </div>
        </div>
    </div>
    @if (User.IsInRole("SystemAdmin"))
    {
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-shield-check display-4 text-danger mb-3 d-block"></i>
                    <h6 class="fw-bold">Audit Log</h6>
                    <p class="text-muted small">System activity and operation logs</p>
                    <a asp-action="AuditLog" class="btn btn-outline-danger btn-sm">View Logs</a>
                </div>
            </div>
        </div>
    }
</div>
