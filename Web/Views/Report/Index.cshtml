@{
    ViewData["Title"] = "Reports";
    int reportCount = User.IsInRole("SystemAdmin") ? 4 : 3;
}

<div class="page-hero">
    <div>
        <p class="eyebrow mb-2">Reporting</p>
        <h2 class="fw-bold mb-2">Reports</h2>
        <p class="mb-0">Operational and administrative reports for dormitory management.</p>
    </div>
    <div class="hero-stat">
        <span class="hero-stat-label">Available views</span>
        <strong>@reportCount</strong>
        <span class="hero-stat-meta">Available report modules</span>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6 col-xl-4">
        <div class="card report-card border-0 h-100">
            <div class="card-body">
                <span class="report-icon">
                    <i class="bi bi-people-fill"></i>
                </span>
                <h4 class="fw-bold">Student Report</h4>
                <p class="text-muted">Review and filter registered students with room, building, and check-in information.</p>
                <a asp-action="StudentReport" class="btn btn-outline-primary btn-sm">View Report</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card report-card alt-1 border-0 h-100">
            <div class="card-body">
                <span class="report-icon">
                    <i class="bi bi-house-door-fill"></i>
                </span>
                <h4 class="fw-bold">Housing Report</h4>
                <p class="text-muted">Track residence periods, check-in dates, and check-out history in one place.</p>
                <a asp-action="HousingReport" class="btn btn-outline-warning btn-sm">View Report</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card report-card alt-2 border-0 h-100">
            <div class="card-body">
                <span class="report-icon">
                    <i class="bi bi-credit-card-2-front-fill"></i>
                </span>
                <h4 class="fw-bold">Payment and Maintenance</h4>
                <p class="text-muted">Combine semester payment progress with open service requests for a broader operational view.</p>
                <a asp-action="PaymentMaintenance" class="btn btn-outline-success btn-sm">View Report</a>
            </div>
        </div>
    </div>
    @if (User.IsInRole("SystemAdmin"))
    {
        <div class="col-md-6 col-xl-4">
            <div class="card report-card alt-3 border-0 h-100">
                <div class="card-body">
                    <span class="report-icon">
                        <i class="bi bi-shield-check"></i>
                    </span>
                    <h4 class="fw-bold">Audit Log</h4>
                    <p class="text-muted">Inspect system activity, operation history, and administrative actions.</p>
                    <a asp-action="AuditLog" class="btn btn-outline-danger btn-sm">View Logs</a>
                </div>
            </div>
        </div>
    }
</div>
