@model IEnumerable<Document>
@{
    var student = ViewBag.Student as Student;
    ViewData["Title"] = $"Documents - {student?.FullName}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Documents</h3>
        <p class="text-muted mb-0">
            Student: <strong>@student?.StudentNumber - @student?.FullName</strong>
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Select Student
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6 class="fw-bold mb-3">
            <i class="bi bi-cloud-upload me-2"></i>Upload New Document
        </h6>
        <form asp-action="Upload" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="studentId" value="@student?.StudentId" />
            <div class="col-md-8">
                <label class="form-label small">File (max 5 MB - pdf, doc, docx, xls, xlsx, png, jpg, txt)</label>
                <input type="file" name="file" class="form-control" required
                       accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.txt" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-upload me-1"></i>Upload
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>File Name</th>
                    <th>Type</th>
                    <th>Uploaded</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <i class="bi bi-file-earmark me-1"></i>@d.FileName
                        </td>
                        <td class="small text-muted">@d.FileType</td>
                        <td class="small">@d.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Download" asp-route-id="@d.DocumentId" class="btn btn-outline-primary" title="Download">
                                    <i class="bi bi-download"></i>
                                </a>
                                @if (User.IsInRole("SystemAdmin") || User.IsInRole("DormitoryManager"))
                                {
                                    <form asp-action="Delete" asp-route-id="@d.DocumentId" asp-route-studentId="@student?.StudentId"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this document?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            <i class="bi bi-folder-x fs-3 d-block mb-2"></i>
                            No documents uploaded for this student yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
